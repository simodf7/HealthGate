@startuml activity_diagram_REPORT
title Activity Diagram - Report Management Service (Progettazione Funzionale)

skinparam backgroundColor #FDFEFE
skinparam activity {
  BackgroundColor #000080
  BorderColor #000060
  FontColor white
  DiamondBackgroundColor #0086b3
  DiamondBorderColor #004466
  StartColor #C0392B
  EndColor #C0392B
}

start

:Ricezione richiesta da API Gateway;
note right
La richiesta può essere di tipo:
- Creazione nuovo report
- Lettura report esistenti
- Generazione PDF
end note

:Verifica connessione a MongoDB;
if (Connessione disponibile?) then (Sì)
  :Instrada la richiesta verso l'operazione corretta;
else (No)
  :Errore 500 "Database non disponibile";
  stop
endif

partition "Operazioni principali" {

  if (Operazione == Creazione report) then (Sì)
    :Valida i dati ricevuti ;
    :Crea documento del report;
    :Salva nel database ;
    :Restituisci conferma ;
  elseif (Operazione == Ricerca report per paziente) then (Sì)
    :Cerca documenti in MongoDB;
    :Restituisci lista report trovati;
  elseif (Operazione == Aggiornamento report) then (Sì)
    :Cerca report ;
    if (Report trovato?) then (Sì)
      :Aggiorna diagnosi e trattamento;
      :Salva modifiche in MongoDB;
    else (No)
      :Errore 404 "Report non trovato";
      stop
    endif
  elseif (Operazione == Generazione PDF) then (Sì)
    :Recupera report ;
    :Richiede dati anagrafici e clinici del paziente;
    :Genera scheda PDF;
    :Restituisci file PDF;
  else (No)
    :Errore 400 "Operazione non riconosciuta";
    stop
  endif
}

:Invia risposta al Gateway con stato dell’operazione;

stop
@enduml
